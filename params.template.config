// =============================================================================
// Amaranth-test: Template configuration file
// Copy this file to params.config and edit the paths below.
// Usage: nextflow run main.nf -c params.config
// =============================================================================

params {
    // === INPUT (REQUIRED) ===
    // Glob pattern for aligned BAM files (one per cell)
    bam_files = "/path/to/aligned/*.bam"

    // Reference gene annotation in GTF format
    reference_gtf = "/path/to/reference.gtf"

    // === OUTPUT ===
    output_dir = "results"
}
